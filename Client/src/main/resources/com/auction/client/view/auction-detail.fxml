<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootContainer" prefHeight="720.0" prefWidth="1100.0" spacing="20.0" styleClass="detail-root" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.auction.controller.AuctionDetailController">

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="detail-header">
        <Button fx:id="backButton" onAction="#handleBack" styleClass="btn-back" text="⬅ Quay Lại" />

        <HBox HBox.hgrow="ALWAYS" />

        <Button fx:id="openLiveBiddingButton" onAction="#handleOpenLiveBidding" styleClass="btn-live" text="📺 Vào Phòng Live" />

        <Button fx:id="refreshButton" onAction="#handleRefresh" styleClass="btn-refresh" text="🔄 Làm Mới" />
    </HBox>

    <HBox spacing="25.0" VBox.vgrow="ALWAYS">

        <VBox minWidth="500.0" spacing="15.0" styleClass="pane-left" HBox.hgrow="ALWAYS">

            <VBox alignment="CENTER" styleClass="image-container" VBox.vgrow="ALWAYS">
                <ImageView fx:id="itemImageView" fitHeight="280.0" fitWidth="460.0" pickOnBounds="true" preserveRatio="true" styleClass="item-image" />
            </VBox>

            <VBox spacing="8.0" styleClass="info-card">
                <Label fx:id="itemNameLabel" styleClass="info-item-name" text="Tên vật phẩm đấu giá" />
                <Label fx:id="sellerLabel" styleClass="info-seller" text="Người bán: ---" />

                <HBox spacing="30.0" styleClass="price-row">
                    <Label fx:id="currentPriceLabel" styleClass="info-price, price-current" text="Giá hiện tại: 0 VNĐ" />
                    <Label fx:id="stepPriceLabel" styleClass="info-price, price-step" text="Bước giá: 0 VNĐ" />
                </HBox>

                <HBox spacing="30.0" styleClass="status-row">
                    <Label fx:id="statusLabel" styleClass="info-status" text="Trạng thái: ---" />
                    <Label fx:id="endTimeLabel" styleClass="info-end-time" text="Kết thúc: --:--" />
                </HBox>
            </VBox>

            <VBox spacing="5.0">
                <Label styleClass="section-sub-title" text="Mô tả sản phẩm:" />
                <TextArea fx:id="descriptionTextArea" editable="false" prefHeight="90.0" wrapText="true" styleClass="description-text" />
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="bid-form-box">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="field-label" text="Nhập số tiền muốn đặt (VNĐ):" />
                    <TextField fx:id="bidAmountField" promptText="Ví dụ: 1,500,000" styleClass="bid-input" />
                </VBox>
                <Button fx:id="placeBidButton" onAction="#handlePlaceBid" styleClass="btn-action, btn-place-bid" text="🔨 Đặt Giá" />
            </HBox>
        </VBox>

        <VBox minWidth="480.0" spacing="10.0" styleClass="pane-right" HBox.hgrow="ALWAYS">
            <Label styleClass="section-title" text="📜 Lịch Sử Đặt Giá Phiên" />

            <TableView fx:id="bidHistoryTable" styleClass="sim-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="bidderNameColumn" prefWidth="130.0" styleClass="col-name" text="Người đặt" />
                    <TableColumn fx:id="bidAmountColumn" prefWidth="120.0" styleClass="col-amount" text="Số tiền (VNĐ)" />
                    <TableColumn fx:id="bidTimeColumn" prefWidth="120.0" styleClass="col-time" text="Thời gian" />
                    <TableColumn fx:id="bidStatusColumn" prefWidth="90.0" styleClass="col-status" text="Trạng thái" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" styleClass="status-bar">
        <Label fx:id="messageLabel" styleClass="status-text" text="Hệ thống sẵn sàng." />
    </HBox>
</VBox>