<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootContainer" prefHeight="750.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <Button fx:id="backButton" onAction="#handleBack" style="-fx-font-weight: bold; -fx-cursor: hand;" text="← Quay lại Dashboard" />
                <Label style="-fx-font-weight: bold;" text="Hệ Thống Quản Trị Hệ Thống (Admin Dashboard)" HBox.hgrow="ALWAYS">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
                <Button onAction="#handleClearForms" style="-fx-cursor: hand;" text="Làm sạch Form ⎋" />
            </children>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.65" BorderPane.alignment="CENTER">
            <items>

                <VBox spacing="20.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Danh sách người dùng hệ thống">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Label>
                                        <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Kích thước trang:" style="-fx-font-size: 12px;" />
                                                <TextField fx:id="userPageSizeField" prefWidth="50.0" />
                                                <Button fx:id="refreshUsersButton" onAction="#handleRefreshUsers" style="-fx-cursor: hand;" text="Tải lại ↻" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                                <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="userIdColumn" prefWidth="70.0" text="User ID" />
                                        <TableColumn fx:id="usernameColumn" prefWidth="120.0" text="Tên tài khoản" />
                                        <TableColumn fx:id="emailColumn" prefWidth="150.0" text="Email" />
                                        <TableColumn fx:id="roleColumn" prefWidth="90.0" text="Vai trò" />
                                        <TableColumn fx:id="statusColumn" prefWidth="90.0" text="Trạng thái" />
                                        <TableColumn fx:id="availableBalanceColumn" prefWidth="120.0" text="Số dư khả dụng" />
                                        <TableColumn fx:id="frozenBalanceColumn" prefWidth="110.0" text="Số dư đóng băng" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button fx:id="previousUserPageButton" onAction="#handlePreviousUserPage" style="-fx-cursor: hand;" text="◀ Trang trước" />
                                        <Label fx:id="userPageLabel" style="-fx-font-weight: bold;" text="Users page 1 / --" />
                                        <Button fx:id="nextUserPageButton" onAction="#handleNextUserPage" style="-fx-cursor: hand;" text="Trang sau ▶" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Nhật ký kiểm duyệt (Audit Logs)">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Label>
                                        <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Kích thước trang:" style="-fx-font-size: 12px;" />
                                                <TextField fx:id="logPageSizeField" prefWidth="50.0" />
                                                <Button fx:id="refreshLogsButton" onAction="#handleRefreshLogs" style="-fx-cursor: hand;" text="Tải lại ↻" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                                <TableView fx:id="logsTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="logIdColumn" prefWidth="70.0" text="Log ID" />
                                        <TableColumn fx:id="logAdminIdColumn" prefWidth="90.0" text="Admin ID" />
                                        <TableColumn fx:id="logActionDetailColumn" prefWidth="250.0" text="Chi tiết hành động kiểm duyệt" />
                                        <TableColumn fx:id="logTargetTypeColumn" prefWidth="100.0" text="Loại đối tượng" />
                                        <TableColumn fx:id="logTargetIdColumn" prefWidth="100.0" text="Mã đối tượng" />
                                        <TableColumn fx:id="logTimestampColumn" prefWidth="140.0" text="Thời gian ghi nhận" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button fx:id="previousLogPageButton" onAction="#handlePreviousLogPage" style="-fx-cursor: hand;" text="◀ Trang trước" />
                                        <Label fx:id="logPageLabel" style="-fx-font-weight: bold;" text="Logs page 1 / --" />
                                        <Button fx:id="nextLogPageButton" onAction="#handleNextLogPage" style="-fx-cursor: hand;" text="Trang sau ▶" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="25.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Khung hành động nghiệp vụ">
                            <font>
                                <Font size="15.0" />
                            </font>
                        </Label>

                        <VBox spacing="8.0" styleClass="admin-card">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Khóa tài khoản hệ thống" />
                                <Label style="-fx-font-size: 11px;" text="User ID cần khóa:" />
                                <TextField fx:id="lockUserIdField" promptText="Chọn dòng ở bảng hoặc nhập ID..." />
                                <Label style="-fx-font-size: 11px;" text="Lý do xử lý:" />
                                <TextField fx:id="lockReasonField" promptText="Nhập lý do vi phạm..." />
                                <Button fx:id="lockUserButton" maxWidth="1.7976931348623157E308" onAction="#handleLockSelectedUser" style="-fx-font-weight: bold; -fx-cursor: hand;" text="Xác nhận khoá tài khoản" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0" styleClass="admin-card">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Hủy phiên đấu giá" />
                                <Label style="-fx-font-size: 11px;" text="Auction ID cần hủy:" />
                                <TextField fx:id="cancelAuctionIdField" promptText="Nhập mã phiên đấu giá..." />
                                <Label style="-fx-font-size: 11px;" text="Lý do hủy bỏ:" />
                                <TextField fx:id="cancelAuctionReasonField" promptText="Nhập lý do vi phạm luật đấu giá..." />
                                <Button fx:id="cancelAuctionButton" maxWidth="1.7976931348623157E308" onAction="#handleCancelAuction" style="-fx-font-weight: bold; -fx-cursor: hand;" text="Xác nhận hủy phiên" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0" styleClass="admin-card">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Gỡ bỏ / Ban vật phẩm" />
                                <Label style="-fx-font-size: 11px;" text="Item ID cần gỡ bỏ:" />
                                <TextField fx:id="deleteItemIdField" promptText="Nhập mã sản phẩm/vật phẩm..." />
                                <Label style="-fx-font-size: 11px;" text="Lý do gỡ bỏ:" />
                                <TextField fx:id="deleteItemReasonField" promptText="Nhập lý do sản phẩm bị cấm..." />
                                <Button fx:id="deleteItemButton" maxWidth="1.7976931348623157E308" onAction="#handleDeleteItem" style="-fx-font-weight: bold; -fx-cursor: hand;" text="Xác nhận xóa vật phẩm" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>

    <bottom>
        <HBox styleClass="status-bar">
            <padding>
                <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
            </padding>
            <children>
                <Label fx:id="messageLabel" style="-fx-font-style: italic;" text="Hệ thống đã sẵn sàng." />
            </children>
        </HBox>
    </bottom>
</BorderPane>