<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootContainer" prefHeight="750.0" prefWidth="1200.0" styleClass="ap-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AdminDashboardController">

    <top>
        <VBox styleClass="ap-top-container">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="ap-header-bar">
                    <padding>
                        <Insets bottom="10.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <Button fx:id="backButton" onAction="#handleBack" styleClass="settings-btn-back" text="← Quay lại Dashboard" />
                        <Label styleClass="sim-screen-title" text="HỆ THỐNG QUẢN TRỊ TRUNG TÂM (ADMIN DASHBOARD)" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleClearForms" styleClass="settings-btn-back" text="Làm sạch Form ⎋" />
                    </children>
                </HBox>

                <HBox styleClass="ap-nav-tabs">
                    <padding>
                        <Insets bottom="10.0" left="15.0" right="15.0" top="0.0" />
                    </padding>
                    <children>
                        <Button fx:id="tabUsersButton" onAction="#handleSwitchToUsersTab" styleClass="ap-btn-nav" text="👥 Quản Lý Người Dùng" />
                        <Button fx:id="tabItemsButton" onAction="#handleSwitchToItemsTab" styleClass="ap-btn-nav" text="📦 Quản Lý Vật Phẩm" />
                        <Button fx:id="tabAuctionsButton" onAction="#handleSwitchToAuctionsTab" styleClass="ap-btn-nav" text="⏳ Quản Lý Phiên Đấu Giá" />
                        <Button fx:id="tabLogsButton" onAction="#handleSwitchToLogsTab" styleClass="ap-btn-nav" text="📜 Nhật Ký Hệ Thống (Logs)" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.7" styleClass="ap-split-pane" BorderPane.alignment="CENTER">
            <items>

                <StackPane styleClass="ap-workspace-pane">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>

                        <VBox fx:id="tabUsersContent" styleClass="ap-tab-content" visible="true">
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="ap-table-header">
                                    <children>
                                        <Label styleClass="ap-table-title" text="Danh sách người dùng hệ thống" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox alignment="CENTER_RIGHT" styleClass="ap-pagination-controls">
                                            <children>
                                                <Label styleClass="ap-text-sm" text="Kích thước trang:" />
                                                <TextField fx:id="userPageSizeField" styleClass="ap-input-sm" text="10" />
                                                <Button fx:id="refreshUsersButton" onAction="#handleRefreshUsers" styleClass="ap-btn-refresh" text="Tải lại ↻" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                                <TableView fx:id="usersTable" styleClass="ap-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="userIdColumn" prefWidth="70.0" text="User ID" />
                                        <TableColumn fx:id="usernameColumn" prefWidth="120.0" text="Tên tài khoản" />
                                        <TableColumn fx:id="emailColumn" prefWidth="150.0" text="Email" />
                                        <TableColumn fx:id="roleColumn" prefWidth="90.0" text="Vai trò" />

                                        <TableColumn fx:id="statusColumn" prefWidth="90.0" text="Trạng thái" />

                                        <TableColumn fx:id="availableBalanceColumn" prefWidth="120.0" text="Số dư khả dụng" />
                                        <TableColumn fx:id="frozenBalanceColumn" prefWidth="110.0" text="Số dư đóng băng" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <HBox alignment="CENTER" styleClass="ap-pagination-bar">
                                    <children>
                                        <Button fx:id="previousUserPageButton" onAction="#handlePreviousUserPage" styleClass="ap-btn-page" text="◀ Trang trước" />
                                        <Label fx:id="userPageLabel" styleClass="ap-page-indicator" text="Users page 1 / --" />
                                        <Button fx:id="nextUserPageButton" onAction="#handleNextUserPage" styleClass="ap-btn-page" text="Trang sau ▶" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox fx:id="tabItemsContent" styleClass="ap-tab-content" visible="false">
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="ap-table-header">
                                    <children>
                                        <Label styleClass="ap-table-title" text="Danh sách vật phẩm chờ kiểm duyệt" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox alignment="CENTER_RIGHT" styleClass="ap-pagination-controls">
                                            <children>
                                                <Label styleClass="ap-text-sm" text="Kích thước trang:" />
                                                <TextField fx:id="itemPageSizeField" styleClass="ap-input-sm" text="10" />
                                                <Button fx:id="refreshItemsButton" onAction="#handleRefreshItems" styleClass="ap-btn-refresh" text="Tải lại ↻" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                                <TableView fx:id="itemsTable" styleClass="ap-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="itemIdColumn" prefWidth="80.0" text="Item ID" />
                                        <TableColumn fx:id="itemNameColumn" prefWidth="200.0" text="Tên vật phẩm" />
                                        <TableColumn fx:id="itemTypeColumn" prefWidth="100.0" text="Loại vật phẩm" />
                                        <TableColumn fx:id="itemPriceColumn" prefWidth="120.0" text="Giá khởi điểm" />

                                        <TableColumn fx:id="itemStatusColumn" prefWidth="120.0" text="Trạng thái duyệt" />

                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <HBox alignment="CENTER" styleClass="ap-pagination-bar">
                                    <children>
                                        <Button fx:id="previousItemPageButton" onAction="#handlePreviousItemPage" styleClass="ap-btn-page" text="◀ Trang trước" />
                                        <Label fx:id="itemPageLabel" styleClass="ap-page-indicator" text="Items page 1 / --" />
                                        <Button fx:id="nextItemPageButton" onAction="#handleNextItemPage" styleClass="ap-btn-page" text="Trang sau ▶" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox fx:id="tabAuctionsContent" styleClass="ap-tab-content" visible="false">
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="ap-table-header">
                                    <children>
                                        <Label styleClass="ap-table-title" text="Danh sách các phiên đấu giá hệ thống" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox alignment="CENTER_RIGHT" styleClass="ap-pagination-controls">
                                            <children>
                                                <Label styleClass="ap-text-sm" text="Kích thước trang:" />
                                                <TextField fx:id="auctionPageSizeField" styleClass="ap-input-sm" text="10" />
                                                <Button fx:id="refreshAuctionsButton" onAction="#handleRefreshAuctions" styleClass="ap-btn-refresh" text="Tải lại ↻" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                                <TableView fx:id="auctionsTable" styleClass="ap-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="auctionIdColumn" prefWidth="80.0" text="Auction ID" />
                                        <TableColumn fx:id="auctionItemIdColumn" prefWidth="180.0" text="Tên vật phẩm" />
                                        <TableColumn fx:id="auctionPriceColumn" prefWidth="120.0" text="Giá hiện hành" />

                                        <TableColumn fx:id="auctionStatusColumn" prefWidth="100.0" text="Trạng thái" />

                                        <TableColumn fx:id="auctionEndTimeColumn" prefWidth="140.0" text="Thời gian đóng" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <HBox alignment="CENTER" styleClass="ap-pagination-bar">
                                    <children>
                                        <Button fx:id="previousAuctionPageButton" onAction="#handlePreviousAuctionPage" styleClass="ap-btn-page" text="◀ Trang trước" />
                                        <Label fx:id="auctionPageLabel" styleClass="ap-page-indicator" text="Auctions page 1 / --" />
                                        <Button fx:id="nextAuctionPageButton" onAction="#handleNextAuctionPage" styleClass="ap-btn-page" text="Trang sau ▶" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox fx:id="tabLogsContent" styleClass="ap-tab-content" visible="false">
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="ap-table-header">
                                    <children>
                                        <Label styleClass="ap-table-title" text="Nhật ký kiểm duyệt hệ thống (Audit Logs)" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox alignment="CENTER_RIGHT" styleClass="ap-pagination-controls">
                                            <children>
                                                <Label styleClass="ap-text-sm" text="Kích thước trang:" />
                                                <TextField fx:id="logPageSizeField" styleClass="ap-input-sm" text="10" />
                                                <Button fx:id="refreshLogsButton" onAction="#handleRefreshLogs" styleClass="ap-btn-refresh" text="Tải lại ↻" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                                <TableView fx:id="logsTable" styleClass="ap-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="logIdColumn" prefWidth="70.0" text="Log ID" />
                                        <TableColumn fx:id="logAdminIdColumn" prefWidth="90.0" text="Admin ID" />
                                        <TableColumn fx:id="logActionDetailColumn" prefWidth="250.0" text="Chi tiết hành động" />
                                        <TableColumn fx:id="logTargetTypeColumn" prefWidth="100.0" text="Loại đối tượng" />
                                        <TableColumn fx:id="logTargetIdColumn" prefWidth="100.0" text="Mã đối tượng" />
                                        <TableColumn fx:id="logTimestampColumn" prefWidth="140.0" text="Thời gian ghi nhận" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <HBox alignment="CENTER" styleClass="ap-pagination-bar">
                                    <children>
                                        <Button fx:id="previousLogPageButton" onAction="#handlePreviousLogPage" styleClass="ap-btn-page" text="◀ Trang trước" />
                                        <Label fx:id="logPageLabel" styleClass="ap-page-indicator" text="Logs page 1 / --" />
                                        <Button fx:id="nextLogPageButton" onAction="#handleNextLogPage" styleClass="ap-btn-page" text="Trang sau ▶" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <StackPane maxWidth="400.0" minWidth="320.0" prefWidth="350.0" styleClass="ap-action-pane">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>

                        <VBox fx:id="actionUserBox" styleClass="ap-action-container" visible="true">
                            <children>
                                <Label styleClass="ap-action-header-user" text="HÀNH ĐỘNG TÀI KHOẢN" />
                                <VBox styleClass="ap-card-action-user">
                                    <children>
                                        <Label styleClass="ap-card-title" text="Khóa tài khoản hệ thống" />
                                        <Label styleClass="ap-input-label" text="User ID cần khóa:" />
                                        <TextField fx:id="lockUserIdField" promptText="Chọn dòng ở bảng hoặc nhập ID..." styleClass="ap-input-field" />
                                        <Label styleClass="ap-input-label" text="Lý do xử lý:" />
                                        <TextField fx:id="lockReasonField" promptText="Nhập lý do vi phạm..." styleClass="ap-input-field" />
                                        <Button fx:id="lockUserButton" maxWidth="1.7976931348623157E308" onAction="#handleLockSelectedUser" styleClass="ap-btn-action-user" text="Xác nhận khoá tài khoản" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox fx:id="actionItemBox" styleClass="ap-action-container" visible="false">
                            <children>
                                <Label styleClass="ap-action-header-item" text="HÀNH ĐỘNG VẬT PHẨM" />
                                <VBox styleClass="ap-card-action-item">
                                    <children>
                                        <Label styleClass="ap-card-title" text="Gỡ bỏ / Ban vật phẩm" />
                                        <Label styleClass="ap-input-label" text="Item ID cần gỡ bỏ:" />
                                        <TextField fx:id="deleteItemIdField" promptText="Nhập mã sản phẩm/vật phẩm..." styleClass="ap-input-field" />
                                        <Label styleClass="ap-input-label" text="Lý do gỡ bỏ:" />
                                        <TextField fx:id="deleteItemReasonField" promptText="Nhập lý do sản phẩm bị cấm..." styleClass="ap-input-field" />
                                        <Button fx:id="deleteItemButton" maxWidth="1.7976931348623157E308" onAction="#handleDeleteItem" styleClass="ap-btn-action-item" text="Xác nhận xóa vật phẩm" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox fx:id="actionAuctionBox" styleClass="ap-action-container" visible="false">
                            <children>
                                <Label styleClass="ap-action-header-auction" text="HÀNH ĐỘNG PHIÊN ĐẤU GIÁ" />
                                <VBox styleClass="ap-card-action-auction">
                                    <children>
                                        <Label styleClass="ap-card-title" text="Hủy phiên đấu giá" />
                                        <Label styleClass="ap-input-label" text="Auction ID cần hủy:" />
                                        <TextField fx:id="cancelAuctionIdField" promptText="Nhập mã phiên đấu giá..." styleClass="ap-input-field" />
                                        <Label styleClass="ap-input-label" text="Lý do hủy bỏ:" />
                                        <TextField fx:id="cancelAuctionReasonField" promptText="Nhập lý do vi phạm luật đấu giá..." styleClass="ap-input-field" />
                                        <Button fx:id="cancelAuctionButton" maxWidth="1.7976931348623157E308" onAction="#handleCancelAuction" styleClass="ap-btn-action-auction" text="Xác nhận hủy phiên" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox fx:id="actionLogBox" styleClass="ap-action-container-log" visible="false">
                            <children>
                                <Label styleClass="ap-log-info-main" text="Chế độ xem nhật ký hệ thống." />
                                <Label styleClass="ap-log-info-sub" text="Không có tác vụ chỉnh sửa tại màn hình này." />
                            </children>
                        </VBox>

                    </children>
                </StackPane>
            </items>
        </SplitPane>
    </center>

    <bottom>
        <HBox styleClass="ap-footer-bar">
            <padding>
                <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
            </padding>
            <children>
                <Label fx:id="messageLabel" styleClass="ap-status-text" text="Hệ thống đã sẵn sàng." />
            </children>
        </HBox>
    </bottom>
</BorderPane>
