<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootContainer" prefHeight="750.0" prefWidth="1050.0" spacing="15.0" styleClass="account-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AccountController">
    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
    </padding>
    <children>

        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="account-header">
            <children>
                <Button fx:id="backButton" onAction="#handleBack" styleClass="account-btn-back" text="⬅ Quay Lại" />
                <Label styleClass="account-header-title" text="|  Thông Tin Tài Khoản Hồ Sơ" HBox.hgrow="ALWAYS" />
                <Button fx:id="refreshButton" onAction="#handleRefresh" styleClass="account-btn-refresh" text="🔄 Làm Mới" />
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="account-scroll-pane" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="18.0" styleClass="account-content-container">
                    <padding>
                        <Insets bottom="30.0" left="2.0" right="12.0" top="5.0" />
                    </padding>
                    <children>

                        <VBox spacing="14.0" styleClass="account-section-card">
                            <children>
                                <Label styleClass="account-section-title" text="THÔNG TIN TÀI KHOẢN" />
                                <HBox styleClass="account-info-row">
                                    <children>
                                        <Label styleClass="account-field-label" text="Mã tài khoản:" />
                                        <Label fx:id="userIdLabel" styleClass="account-field-value" text="---" />
                                    </children>
                                </HBox>
                                <HBox styleClass="account-info-row">
                                    <children>
                                        <Label styleClass="account-field-label" text="Tên đăng nhập:" />
                                        <Label fx:id="usernameLabel" styleClass="account-field-value" text="---" />
                                    </children>
                                </HBox>
                                <HBox styleClass="account-info-row">
                                    <children>
                                        <Label styleClass="account-field-label" text="Email liên hệ:" />
                                        <Label fx:id="emailLabel" styleClass="account-field-value" text="---" />
                                    </children>
                                </HBox>
                                <HBox styleClass="account-info-row">
                                    <children>
                                        <Label styleClass="account-field-label" text="Vai trò:" />
                                        <Label fx:id="roleLabel" styleClass="account-field-value" text="---" />
                                    </children>
                                </HBox>
                                <HBox styleClass="account-info-row">
                                    <children>
                                        <Label styleClass="account-field-label" text="Trạng thái:" />
                                        <Label fx:id="statusLabel" styleClass="account-field-value" text="---" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox fx:id="walletSection" spacing="14.0" styleClass="account-section-card">
                            <children>
                                <Label styleClass="account-section-title" text="THÔNG TIN SỐ DƯ VÍ" />
                                <HBox styleClass="account-info-row">
                                    <children>
                                        <Label styleClass="account-field-label" text="Số dư khả dụng:" />
                                        <Label fx:id="availableBalanceLabel" styleClass="account-balance-available" text="0 VNĐ" />
                                    </children>
                                </HBox>
                                <HBox styleClass="account-info-row">
                                    <children>
                                        <Label styleClass="account-field-label" text="Đang đóng băng (Đặt cọc):" />
                                        <Label fx:id="frozenBalanceLabel" styleClass="account-balance-frozen" text="0 VNĐ" />
                                    </children>
                                </HBox>
                                <HBox styleClass="account-info-row-total">
                                    <children>
                                        <Label styleClass="account-field-label-total" text="Tổng số dư thực tế:" />
                                        <Label fx:id="totalBalanceLabel" styleClass="account-balance-total" text="0 VNĐ" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="14.0" styleClass="account-section-card">
                            <children>
                                <Label styleClass="account-section-title" text="SỐ LIỆU ĐÁNH GIÁ &amp; HỆ THỐNG" />

                                <VBox fx:id="bidderSection" styleClass="account-nested-row">
                                    <children>
                                        <HBox styleClass="account-info-row">
                                            <children>
                                                <Label styleClass="account-field-label" text="Số phiên đấu giá đã và đang tham gia:" />
                                                <Label fx:id="joinedAuctionCountLabel" styleClass="account-stat-value" text="0" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="sellerSection" styleClass="account-nested-row">
                                    <children>
                                        <HBox styleClass="account-info-row">
                                            <children>
                                                <Label styleClass="account-field-label" text="Số view Come My Way trong 8p đầu:" />
                                                <Label styleClass="account-stat-value" text="1.000.000" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="adminSection" styleClass="account-nested-row-admin">
                                    <children>
                                        <Label styleClass="account-admin-text" text="Quyền hạn hệ thống: Quản trị viên (Toàn quyền quản lý danh mục và tài khoản)." wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER_LEFT" styleClass="account-status-bar">
            <children>
                <Label fx:id="messageLabel" styleClass="account-status-text" text="Hệ thống sẵn sàng." />
            </children>
            <padding>
                <Insets bottom="6.0" left="15.0" right="15.0" top="6.0" />
            </padding>
        </HBox>
    </children>
</VBox>
