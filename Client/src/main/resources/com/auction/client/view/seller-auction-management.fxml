<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="rootContainer" prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.SellerAuctionController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="50.0" styleClass="header-bar">
                    <children>
                        <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="title-label" text="Quản Lý Phiên Đấu Giá" />
                                <Label fx:id="messageLabel" styleClass="status-label" text="Sẵn sàng" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#handleLoadSellerAuctions" styleClass="button-refresh" text="🔄 Làm Mới" />
                                <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="button-back" text="⬅ Quay Lại" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="10.0" />
                    </padding>
                </HBox>

                <SplitPane dividerPositions="0.68" focusTraversable="true" VBox.vgrow="ALWAYS" styleClass="main-split-pane">
                    <items>

                        <AnchorPane minWidth="400.0">
                            <children>
                                <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <children>
                                        <Label styleClass="section-title" text="Danh sách phiên đấu giá của bạn" />
                                        <TableView fx:id="sellerAuctionsTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="auctionIdColumn" prefWidth="80.0" text="Mã Phiên" />
                                                <TableColumn fx:id="auctionItemNameColumn" prefWidth="180.0" text="Tên Vật Phẩm" />
                                                <TableColumn fx:id="auctionStatusColumn" prefWidth="100.0" text="Trạng Thái" />
                                                <TableColumn fx:id="auctionStartTimeColumn" prefWidth="130.0" text="Thời Gian Bắt Đầu" />
                                                <TableColumn fx:id="auctionEndTimeColumn" prefWidth="130.0" text="Thời Gian Kết Thúc" />
                                                <TableColumn fx:id="auctionStepPriceColumn" prefWidth="110.0" text="Bước Giá" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>
                            </children>
                        </AnchorPane>

                        <AnchorPane minWidth="280.0" styleClass="form-card">
                            <children>
                                <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <padding>
                                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                                    </padding>
                                    <children>
                                        <Label styleClass="section-title" text="Chỉnh Sửa Phiên Đấu Giá" />

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="form-label" text="Bước giá (VNĐ):" />
                                                <TextField fx:id="auctionStepPriceField" promptText="Ví dụ: 50000" prefHeight="30.0" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="form-label" text="Thời gian bắt đầu:" />
                                                <TextField fx:id="auctionStartTimeField" promptText="dd/MM/yyyy HH:mm" prefHeight="30.0" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="form-label" text="Thời gian kết thúc:" />
                                                <TextField fx:id="auctionEndTimeField" promptText="dd/MM/yyyy HH:mm" prefHeight="30.0" />
                                            </children>
                                        </VBox>

                                        <VBox alignment="BOTTOM_CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Button fx:id="updateAuctionButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleUpdateAuction" prefHeight="35.0" styleClass="button-submit" text="💾 Lưu Cập Nhật" />
                                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleClearUpdateForm" prefHeight="30.0" styleClass="button-clear" text="❌ Hủy Chọn / Xóa Form" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </AnchorPane>
                    </items>
                </SplitPane>

            </children>
        </VBox>
    </children>
</AnchorPane>