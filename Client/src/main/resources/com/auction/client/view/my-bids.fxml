<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="rootContainer" styleClass="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.MyBidsController">
    <children>
        <VBox prefHeight="600.0" prefWidth="850.0" spacing="15.0" styleClass="content-pane">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="4.0" minWidth="300.0">
                            <children>
                                <Label styleClass="section-title" text="LỊCH SỬ ĐẶT GIÁ CỦA TÔI" />
                                <Label fx:id="messageLabel" styleClass="status-message-label" text="Đang tải dữ liệu..." />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="Kích thước trang:" styleClass="status-message-label" />
                                <TextField fx:id="pageSizeField" prefWidth="55.0" alignment="CENTER" text="10" />
                                <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-secondary" text="🔄 Làm mới" />
                                <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="btn-danger" text="Quay lại" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="myBidsTable" styleClass="auction-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="amountColumn" minWidth="220.0" prefWidth="-1.0" text="Số tiền đặt" />
                        <TableColumn fx:id="statusColumn" minWidth="180.0" prefWidth="-1.0" text="Trạng thái lượt bid" />
                        <TableColumn fx:id="timeColumn" minWidth="250.0" prefWidth="-1.0" text="Thời gian thực hiện" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 5 0 0 0;">
                    <children>
                        <Label fx:id="totalBidsLabel" styleClass="total-bids-label" text="Tổng cộng: 0 lượt bid" />

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Button fx:id="previousPageButton" mnemonicParsing="false" onAction="#handlePreviousPage" text="◀" prefWidth="38.0" prefHeight="32.0" styleClass="btn-nav" />
                                <Label fx:id="pageLabel" text="Trang 1 / 1" styleClass="section-title" style="-fx-font-size: 13px; -fx-padding: 0 4;" />
                                <Button fx:id="nextPageButton" mnemonicParsing="false" onAction="#handleNextPage" text="▶" prefWidth="38.0" prefHeight="32.0" styleClass="btn-nav" />
                            </children>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Region prefWidth="150.0" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</StackPane>