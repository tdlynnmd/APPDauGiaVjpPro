<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import java.lang.String?>

<StackPane fx:id="rootPane" styleClass="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionListController">
    <children>
        <VBox prefHeight="600.0" prefWidth="850.0" spacing="15.0" styleClass="content-pane">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="2.0" minWidth="180.0">
                            <children>
                                <Label styleClass="section-title" text="DANH SÁCH PHIÊN ĐẤU GIÁ" style="-fx-font-weight: bold; -fx-font-size: 15px;" />
                                <Label fx:id="messageLabel" styleClass="status-message-label" text="Đang tải dữ liệu..." />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <TextField fx:id="searchAuctionField" promptText="Tìm tên vật phẩm hoặc ID..." prefWidth="200.0" />
                                <Button mnemonicParsing="false" onAction="#handleSearchAction" styleClass="btn-primary" text="Tìm kiếm" />
                            </children>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="Kích thước trang:" />
                                <TextField fx:id="pageSizeField" prefWidth="50.0" alignment="CENTER" text="10" />
                                <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-secondary" text="🔄 Làm mới" />
                                <Button mnemonicParsing="false" onAction="#handleViewDetail" styleClass="btn-primary" text="Xem chi tiết" />
                                <Button mnemonicParsing="false" onAction="#handleBack" styleClass="btn-danger" text="Quay lại" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="15.0" styleClass="header-balance-container">
                    <children>
                        <VBox>
                            <styleClass>
                                <String fx:value="mini-balance-card" />
                                <String fx:value="mini-card-available" />
                            </styleClass>
                            <children>
                                <Label styleClass="mini-card-title" text="Khả dụng" />
                                <Label fx:id="headerAvailableBalance" styleClass="mini-card-value" text="0 VNĐ" />
                            </children>
                        </VBox>
                        <VBox>
                            <styleClass>
                                <String fx:value="mini-balance-card" />
                                <String fx:value="mini-card-frozen" />
                            </styleClass>
                            <children>
                                <Label styleClass="mini-card-title" text="Đóng băng" />
                                <Label fx:id="headerFrozenBalance" styleClass="mini-card-value" text="0 VNĐ" />
                            </children>
                        </VBox>
                        <VBox>
                            <styleClass>
                                <String fx:value="mini-balance-card" />
                                <String fx:value="mini-card-total" />
                            </styleClass>
                            <children>
                                <Label styleClass="mini-card-title" text="Tổng số dư" />
                                <Label fx:id="headerTotalBalance" styleClass="mini-card-value" text="0 VNĐ" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <TableView fx:id="auctionTable" prefHeight="200.0" prefWidth="200.0" styleClass="auction-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="auctionIdColumn" minWidth="120.0" prefWidth="-1.0" text="Mã ID Phiên" />
                        <TableColumn fx:id="itemNameColumn" minWidth="200.0" prefWidth="-1.0" text="Tên vật phẩm" />
                        <TableColumn fx:id="itemTypeColumn" minWidth="100.0" prefWidth="-1.0" text="Phân loại" />
                        <TableColumn fx:id="currentPriceColumn" minWidth="150.0" prefWidth="-1.0" text="Giá hiện tại" />
                        <TableColumn fx:id="statusColumn" minWidth="120.0" prefWidth="-1.0" text="Trạng thái" />
                        <TableColumn fx:id="startTimeColumn" minWidth="160.0" prefWidth="-1.0" text="Thời gian bắt đầu" />
                        <TableColumn fx:id="endTimeColumn" minWidth="160.0" prefWidth="-1.0" text="Thời gian kết thúc" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER" style="-fx-padding: 5 0 0 0;">
                    <children>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Button fx:id="prevPageButton" mnemonicParsing="false" onAction="#handlePrevPage" text="◀" prefWidth="35.0" />
                                <Label fx:id="pageInfoLabel" text="Trang 1 / 1" style="-fx-font-weight: bold;" />
                                <Button fx:id="nextPageButton" mnemonicParsing="false" onAction="#handleNextPage" text="▶" prefWidth="35.0" />
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>