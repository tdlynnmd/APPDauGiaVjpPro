<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootContainer" prefHeight="750.0" prefWidth="1050.0" spacing="15.0" styleClass="settings-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.SettingsController">
    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
    </padding>
    <children>

        <HBox alignment="CENTER_LEFT" minHeight="50.0" styleClass="settings-header">
            <children>
                <HBox alignment="CENTER_LEFT" prefWidth="150.0">
                    <children>
                        <Button fx:id="backButton" onAction="#handleBack" styleClass="settings-btn-back" text="⬅ Quay Lại" />
                    </children>
                </HBox>

                <HBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" styleClass="settings-header-title-center" text="🛠  Settings" />
                    </children>
                </HBox>

                <HBox prefWidth="150.0" />
            </children>
        </HBox>

        <HBox spacing="25.0" VBox.vgrow="ALWAYS">
            <children>

                <VBox maxWidth="288.0" minWidth="220.0" prefHeight="602.0" prefWidth="288.0" spacing="8.0" styleClass="settings-sidebar" HBox.hgrow="NEVER">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-opacity: 0.7;" styleClass="settings-sidebar-title" text="Mục Cài Đặt" />

                        <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleMenuThongTinHoSo" styleClass="settings-sidebar-btn" text="👤 Chỉnh Sửa Thông Tin Hồ Sơ" />
                        <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleMenuDoiMatKhau" styleClass="settings-sidebar-btn" text="🔒 Đổi Mật Khẩu" />
                        <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleMenuGiaoDien" styleClass="settings-sidebar-btn" text="🎨 Chuyển Đổi Giao Diện Ứng Dụng" />
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>

                <ScrollPane fx:id="settingsScrollPane" fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll-pane" vbarPolicy="AS_NEEDED" HBox.hgrow="ALWAYS">
                    <content>
                        <VBox fx:id="mainContentContainer" spacing="25.0" styleClass="settings-content-container">
                            <padding>
                                <Insets bottom="20.0" left="5.0" right="15.0" top="5.0" />
                            </padding>
                            <children>

                                <VBox fx:id="cardThongTinHoSo" spacing="15.0" styleClass="settings-section-card">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" styleClass="settings-section-title" text="👤 CHỈNH SỬA THÔNG TIN HỒ SƠ" />

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="settings-field-label" text="Tên người dùng (Username):" />
                                                <TextField fx:id="usernameField" promptText="Nhập username mới..." styleClass="settings-input" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="settings-field-label" text="Địa chỉ Email:" />
                                                <TextField fx:id="emailField" promptText="Nhập email mới..." styleClass="settings-input" />
                                            </children>
                                        </VBox>

                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button fx:id="updateProfileButton" onAction="#handleUpdateProfile" styleClass="settings-btn-primary" text="💾 Lưu thông tin" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="cardDoiMatKhau" spacing="15.0" styleClass="settings-section-card">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" styleClass="settings-section-title" text="🔒 ĐỔI MẬT KHẨU" />

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="settings-field-label" text="Mật khẩu hiện tại:" />
                                                <PasswordField fx:id="oldPasswordField" promptText="Nhập mật khẩu hiện tại..." styleClass="settings-input" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="settings-field-label" text="Mật khẩu mới (Tối thiểu 8 ký tự):" />
                                                <PasswordField fx:id="newPasswordField" promptText="Nhập mật khẩu mới..." styleClass="settings-input" />
                                            </children>
                                        </VBox>

                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button fx:id="updatePasswordButton" onAction="#handleUpdatePassword" styleClass="settings-btn-danger" text="🔑 Đổi mật khẩu" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="cardGiaoDien" spacing="15.0" styleClass="settings-section-card">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" styleClass="settings-section-title" text="🎨 CHUYỂN ĐỔI GIAO DIỆN ỨNG DỤNG" />

                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label text="Chế độ hiện tại:" />
                                                <Label fx:id="currentThemeLabel" style="-fx-font-weight: bold;" text="---" />
                                            </children>
                                        </HBox>

                                        <Button fx:id="themeToggleButton" maxWidth="250.0" onAction="#handleToggleTheme" styleClass="settings-btn-theme" text="Chuyển đổi giao diện" />
                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" styleClass="settings-status-bar">
            <children>
                <Label fx:id="messageLabel" styleClass="settings-status-text" text="Hệ thống sẵn sàng." />
            </children>
            <padding>
                <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
            </padding>
        </HBox>

    </children>
</VBox>
