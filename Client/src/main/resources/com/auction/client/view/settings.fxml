<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootContainer" prefHeight="750.0" prefWidth="1050.0" spacing="20.0" styleClass="settings-root" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.SettingsController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>

        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="settings-header">
            <children>
                <Button fx:id="backButton" onAction="#handleBack" text="⬅ Quay Lại" />
                <Label styleClass="settings-header-title" text="|  Cấu Hình Cài Đặt Tài Khoản" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <HBox spacing="25.0" VBox.vgrow="ALWAYS">
            <children>

                <VBox spacing="20.0" HBox.hgrow="ALWAYS" styleClass="settings-left-pane">
                    <children>

                        <VBox spacing="12.0" styleClass="settings-card">
                            <children>
                                <Label styleClass="settings-section-title" text="👤 THÔNG TIN HỒ SƠ" />

                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="settings-field-label" text="Tên người dùng (Username):" />
                                        <TextField fx:id="usernameField" promptText="Nhập username mới..." styleClass="settings-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="settings-field-label" text="Địa chỉ Email:" />
                                        <TextField fx:id="emailField" promptText="Nhập email mới..." styleClass="settings-input" />
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button fx:id="updateProfileButton" onAction="#handleUpdateProfile" styleClass="settings-btn-primary" text="💾 Lưu thông tin" />
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                        </VBox>

                        <VBox spacing="12.0" styleClass="settings-card">
                            <children>
                                <Label styleClass="settings-section-title" text="🔒 ĐỔI MẬT KHẨU" />

                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="settings-field-label" text="Mật khẩu hiện tại:" />
                                        <PasswordField fx:id="oldPasswordField" promptText="Nhập mật khẩu hiện tại..." styleClass="settings-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label styleClass="settings-field-label" text="Mật khẩu mới (Tối thiểu 8 ký tự):" />
                                        <PasswordField fx:id="newPasswordField" promptText="Nhập mật khẩu mới..." styleClass="settings-input" />
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button fx:id="updatePasswordButton" onAction="#handleUpdatePassword" styleClass="settings-btn-danger" text="🔑 Đổi mật khẩu" />
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                        </VBox>

                    </children>
                </VBox>

                <VBox maxWidth="350.0" minWidth="300.0" spacing="15.0" styleClass="settings-right-pane" HBox.hgrow="NEVER">
                    <children>
                        <VBox spacing="15.0" styleClass="settings-card">
                            <children>
                                <Label styleClass="settings-section-title" text="🎨 GIAO DIỆN ỨNG DỤNG" />

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Chế độ hiện tại:" />
                                        <Label fx:id="currentThemeLabel" style="-fx-font-weight: bold;" text="---" />
                                    </children>
                                </HBox>

                                <Button fx:id="themeToggleButton" maxWidth="1.7976931348623157E308" onAction="#handleToggleTheme" styleClass="settings-btn-theme" text="Chuyển đổi giao diện" />
                            </children>
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                        </VBox>
                    </children>
                </VBox>

            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" styleClass="settings-status-bar">
            <children>
                <Label fx:id="messageLabel" styleClass="settings-status-text" text="Hệ thống sẵn sàng." />
            </children>
            <padding>
                <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
            </padding>
        </HBox>

    </children>
</VBox>