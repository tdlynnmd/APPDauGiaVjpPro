# -----------------------------------------------------------------------------
# CẤU HÌNH DATABASE & SERVER (AUCTION SYSTEM)
# Hướng dẫn: Sao chép file này thành file '.env' ở thư mục gốc của dự án và chỉnh sửa.
# Nếu không tạo file '.env', hệ thống mặc định kết nối tới Local MySQL (localhost:3306, user 'root', không mật khẩu).
# -----------------------------------------------------------------------------

# ==========================================
# 1. Cấu hình kết nối Database
# ==========================================

# --- CÁCH A: Điền chi tiết từng thông số đơn lẻ ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vnu_auction_system
DB_USER=root
# Mật khẩu database local của bạn (để trống nếu không có mật khẩu)
DB_PASSWORD=

# --- CÁCH B: Hoặc sử dụng chuỗi kết nối JDBC trực tiếp (Nếu khai báo sẽ ghi đè Cách A) ---
# DB_URL=jdbc:mysql://localhost:3306/vnu_auction_system?useSSL=false&allowPublicKeyRetrieval=true

# ==========================================
# 2. Cấu hình bảo mật & Cổng chạy dịch vụ
# ==========================================

# Ép buộc sử dụng SSL (Đặt 'true' nếu kết nối Azure/AWS MySQL yêu cầu bảo mật SSL)
DB_USE_SSL=false

# Cổng khởi chạy dịch vụ Socket Server
AUCTION_SERVER_PORT=5555
